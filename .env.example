# ============================================================================
# Signal Bot Configuration
# ============================================================================

# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------
# Type: sqlite or postgres
DATABASE_TYPE=sqlite

# SQLite: Path to database file (relative or absolute)
# PostgreSQL: Connection string (postgresql://user:pass@host:port/db)
DATABASE_PATH=./data/signal-bot.db

# ----------------------------------------------------------------------------
# Signal API
# ----------------------------------------------------------------------------
# URL of signal-cli-rest-api (default for docker-compose: http://localhost:8080)
SIGNAL_API_URL=http://localhost:8080

# Your Signal phone number in E.164 format (e.g., +14155551234)
SIGNAL_PHONE_NUMBER=+14155551234

# Polling interval in milliseconds (default: 5000)
SIGNAL_POLL_INTERVAL=5000

# ----------------------------------------------------------------------------
# Access Control
# ----------------------------------------------------------------------------
# Comma-separated list of allowed phone numbers (E.164 format)
# Example: +14155551234,+14155555678
SIGNAL_ALLOWED_SENDERS=+14155551234

# Comma-separated list of allowed group IDs
# Leave empty if you don't want to respond in groups
# Example: group.abc123,group.def456
SIGNAL_ALLOWED_GROUPS=

# Names the bot responds to (comma-separated, case-insensitive)
# Used for @mentions in groups
SIGNAL_BOT_NAMES=Bot,Assistant

# ----------------------------------------------------------------------------
# LLM Configuration
# ----------------------------------------------------------------------------
# LLM Provider: anthropic, openai, lmstudio, vertex, or bedrock
# - anthropic: Use Claude models via Anthropic API
# - openai: Use OpenAI API
# - lmstudio: Use local models via LM Studio
# - vertex: Use Google Gemini models via Vertex AI (Google Cloud)
# - bedrock: Use AWS Bedrock (Claude models on AWS)
LLM_PROVIDER=anthropic

# API Key (required for anthropic, openai, and vertex)
# Anthropic: Get from https://console.anthropic.com/
# OpenAI: Get from https://platform.openai.com/api-keys
# Vertex AI: Use GOOGLE_CLOUD_API_KEY (see below)
# LM Studio: Not required (or set to 'not-needed')
# Bedrock: Not required (uses AWS_BEARER_TOKEN_BEDROCK)
ANTHROPIC_API_KEY=sk-ant-...

# Google Cloud API Key (required for vertex provider)
# Get from: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLOUD_API_KEY=your-google-cloud-api-key

# AWS Bedrock Configuration (required for bedrock provider)
# Get bearer token from AWS using your credentials
# AWS_BEARER_TOKEN_BEDROCK=your-aws-bearer-token
# AWS_REGION=us-east-1

# Base URL (required for openai and lmstudio, optional for vertex)
# OpenAI: https://api.openai.com
# LM Studio: http://localhost:1234 (default LM Studio port)
# Vertex AI: https://aiplatform.googleapis.com/v1/publishers/google/models (default)
# LLM_BASE_URL=http://localhost:1234

# Model name
# Anthropic: claude-opus-4-20250514, claude-sonnet-4-20250514, claude-haiku-4-20250514
# OpenAI: gpt-4-turbo, gpt-4, gpt-3.5-turbo
# LM Studio: Use the model name shown in LM Studio (e.g., llama-3-8b-instruct)
# Vertex AI: gemini-2.5-pro, gemini-2.0-flash-exp, gemini-1.5-pro
# Bedrock: us.anthropic.claude-sonnet-4-5-v2:0, us.anthropic.claude-opus-4-5-v2:0
LLM_MODEL=claude-sonnet-4-20250514

# Maximum tokens for responses (optional, uses model default if not set)
# LLM_MAX_TOKENS=4096

# Example LM Studio configuration:
# LLM_PROVIDER=lmstudio
# LLM_BASE_URL=http://localhost:1234
# LLM_MODEL=llama-3-8b-instruct
# ANTHROPIC_API_KEY=not-needed

# Example Vertex AI configuration:
# LLM_PROVIDER=vertex
# GOOGLE_CLOUD_API_KEY=your-google-cloud-api-key
# LLM_MODEL=gemini-2.5-pro
# ANTHROPIC_API_KEY=not-needed

# Example AWS Bedrock configuration:
# LLM_PROVIDER=bedrock
# AWS_BEARER_TOKEN_BEDROCK=your-aws-bearer-token
# AWS_REGION=us-east-1
# LLM_MODEL=us.anthropic.claude-sonnet-4-5-v2:0
# ANTHROPIC_API_KEY=not-needed

# ----------------------------------------------------------------------------
# Optional Features
# ----------------------------------------------------------------------------
# Directory for file operations (optional)
# If not set, file tools will be disabled
# WORKSPACE_DIR=./workspace

# Sandboxed directory for file operations (recommended over WORKSPACE_DIR)
# Bot can only read/write within this directory
# SANDBOX_DIR=./sandbox

# Enable activity logging (tool calls, responses)
# Set to 'false' to disable (default: true)
ENABLE_ACTIVITY_LOGGING=true

# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# ----------------------------------------------------------------------------
# Rate Limiting / Slow Mode
# ----------------------------------------------------------------------------
# Enable slow mode to prevent rate limiting (useful for free tier or shared keys)
# ANTHROPIC_SLOW_MODE=true

# Tokens per minute limit (default: 30000)
# Adjust based on your API tier
# ANTHROPIC_RATE_LIMIT_TPM=30000

# ----------------------------------------------------------------------------
# MCP (Model Context Protocol) - Optional
# ----------------------------------------------------------------------------
# Enable MCP server integration (default: false)
# See mcp-config.example.json for server configuration
# MCP_ENABLED=true
# MCP_CONFIG_FILE=./mcp-config.json

# ----------------------------------------------------------------------------
# Optional Integrations
# ----------------------------------------------------------------------------

# Discord Integration
# Create a bot at https://discord.com/developers/applications
# DISCORD_TOKEN=your-discord-bot-token
# DISCORD_CLIENT_ID=your-discord-client-id
# DISCORD_GUILD_ID=your-discord-guild-id

# Attio CRM Integration
# Get your API key from Attio settings
# ATTIO_API_KEY=your-attio-api-key

# Google Drive Integration
# Path to your service account JSON key file
# GOOGLE_DRIVE_SERVICE_ACCOUNT_KEY_PATH=./credentials/google-drive-service-account.json

# Open Measures API (social media analytics)
# OPEN_MEASURES_API_KEY=your-open-measures-api-key
