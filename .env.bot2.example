# ============================================================================
# Signal Bot 2 Configuration - Using LM Studio (Local Model)
# ============================================================================

# Database
DATABASE_TYPE=sqlite
DATABASE_PATH=./data/bot2.db

# Signal API
SIGNAL_API_URL=http://localhost:8081
SIGNAL_PHONE_NUMBER=+14155552222
SIGNAL_POLL_INTERVAL=5000

# Access Control
SIGNAL_ALLOWED_SENDERS=+14155558888
SIGNAL_ALLOWED_GROUPS=
SIGNAL_BOT_NAMES=Bot2,LocalBot

# LLM Configuration - LM Studio (Local)
LLM_PROVIDER=lmstudio
LLM_BASE_URL=http://localhost:1234
LLM_MODEL=llama-3.2-3b-instruct
ANTHROPIC_API_KEY=not-needed

# Optional Features
WORKSPACE_DIR=./workspace-bot2
ENABLE_ACTIVITY_LOGGING=true
LOG_LEVEL=info
