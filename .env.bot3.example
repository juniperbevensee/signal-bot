# ============================================================================
# Signal Bot 3 Configuration - Haiku (Fast & Cheap)
# ============================================================================

# Database
DATABASE_TYPE=sqlite
DATABASE_PATH=./data/bot3.db

# Signal API
SIGNAL_API_URL=http://localhost:8082
SIGNAL_PHONE_NUMBER=+14155553333
SIGNAL_POLL_INTERVAL=5000

# Access Control - Group Bot Example
SIGNAL_ALLOWED_SENDERS=
SIGNAL_ALLOWED_GROUPS=group.abc123,group.def456
SIGNAL_BOT_NAMES=Bot3,QuickBot

# LLM Configuration - Claude Haiku (Fastest, Cheapest)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-haiku-4-20250514

# Optional Features
WORKSPACE_DIR=./workspace-bot3
ENABLE_ACTIVITY_LOGGING=true
LOG_LEVEL=info
