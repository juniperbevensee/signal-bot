# Example Bot Configuration File
# Copy this file to .env.bot1, .env.bot2, etc.
# and update the values for each bot instance

# Signal API Configuration
# Each bot should point to a different Signal API instance
SIGNAL_API_URL=http://localhost:8080  # Change port for each bot (8080, 8081, etc.)
SIGNAL_NUMBER=+1234567890              # Unique phone number for this bot

# Bot Identity
BOT_NAME=MyBot1                        # Friendly name for this bot instance

# OpenAI Configuration (if using AI features)
OPENAI_API_KEY=sk-...                  # Your OpenAI API key

# Database Configuration (if applicable)
DATABASE_URL=postgresql://...          # Database connection string

# Logging
LOG_LEVEL=info                         # debug, info, warn, error

# Other bot-specific settings
# Add any additional configuration needed by your bot

# Example for multiple bots:
# 
# .env.bot1:
#   SIGNAL_API_URL=http://localhost:8080
#   SIGNAL_NUMBER=+11111111111
#   BOT_NAME=ProductionBot
#
# .env.bot2:
#   SIGNAL_API_URL=http://localhost:8081
#   SIGNAL_NUMBER=+12222222222
#   BOT_NAME=TestBot
#
# .env.bot3:
#   SIGNAL_API_URL=http://localhost:8082
#   SIGNAL_NUMBER=+13333333333
#   BOT_NAME=DevBot

