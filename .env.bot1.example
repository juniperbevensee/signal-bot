# ============================================================================
# Signal Bot 1 Configuration
# ============================================================================

# Database
DATABASE_TYPE=sqlite
DATABASE_PATH=./data/bot1.db

# Signal API
SIGNAL_API_URL=http://localhost:8080
SIGNAL_PHONE_NUMBER=+14155551111
SIGNAL_POLL_INTERVAL=5000

# Access Control
SIGNAL_ALLOWED_SENDERS=+14155559999
SIGNAL_ALLOWED_GROUPS=
SIGNAL_BOT_NAMES=Bot1,Assistant1

# LLM Configuration
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-20250514

# Optional Features
WORKSPACE_DIR=./workspace-bot1
ENABLE_ACTIVITY_LOGGING=true
LOG_LEVEL=info
