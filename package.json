{
  "name": "signal-bot",
  "version": "1.0.0",
  "description": "Community-hosted Signal bot with local database storage",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && npm run build:web",
    "build:web": "cd web && vite build",
    "start": "tsx src/index.ts",
    "start:all": "tsx scripts/start-all.ts",
    "stop:all": "tsx scripts/start-all.ts stop",
    "status": "tsx scripts/start-all.ts status",
    "logs": "tsx scripts/start-all.ts logs",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "tsx watch src/index.ts",
    "dev:web": "cd web && vite",
    "preview": "cd web && vite preview",
    "setup:signal": "tsx scripts/setup-signal.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "signal",
    "bot",
    "ai",
    "claude",
    "database",
    "self-hosted"
  ],
  "author": "",
  "license": "GPL-3.0",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "better-sqlite3": "^11.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.18.2",
    "node-cron": "^3.0.3",
    "pm2": "^6.0.14",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.0",
    "tsx": "^4.21.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@testing-library/react": "^14.1.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.10",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^2.1.8",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.32",
    "supertest": "^6.3.3",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.3",
    "vite": "^5.0.0",
    "vitest": "^2.1.8"
  },
  "optionalDependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
